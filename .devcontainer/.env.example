# =============================================================================
# .devcontainer/.env reference — DOCUMENTATION ONLY (not loaded by Compose).
#
# The actual .env is generated by .devcontainer/init-env.sh from:
#   - /pixi.toml [workspace].name      -> COMPOSE_PROJECT_NAME
#   - host UID/GID                     -> HOST_UID, HOST_GID
#   - environment-aware defaults below -> the rest
#
# Workflow:
#   1. Edit /pixi.toml [workspace].name when forking the template.
#   2. Run `bash .devcontainer/init-env.sh` (or open in VS Code; the
#      `initializeCommand` runs it automatically).
#   3. To override a default, edit the generated .devcontainer/.env directly,
#      OR delete it and re-run init-env.sh with the override exported in your
#      shell (e.g. `CUDA_VERSION=12.6.0 bash .devcontainer/init-env.sh`).
# =============================================================================

# --- Identity (auto-derived; do not edit by hand) -----------------------------
# COMPOSE_PROJECT_NAME comes from pixi.toml [workspace].name and feeds:
#   - the docker image tag (${COMPOSE_PROJECT_NAME}:latest)
#   - the network/volume prefix
#   - the Claude Code session-history directory
#     (~/.claude-stacks/${COMPOSE_PROJECT_NAME}/...)
COMPOSE_PROJECT_NAME=my-project

# Host UID/GID for non-root container user matching (auto-detected).
HOST_UID=1000
HOST_GID=1000

# --- Container-startup scalars (override as needed) ---------------------------

# Base image tags: nvidia/cuda:${CUDA_VERSION}-devel-ubuntu${UBUNTU_VERSION}.
CUDA_VERSION=12.8.0
UBUNTU_VERSION=24.04

# Workspace mount point inside the container. Must equal devcontainer.json's
# `workspaceFolder` if you use VS Code Dev Containers (devcontainer.json does
# not read .env, so the two are kept in sync manually — default works for both).
WORKSPACE_DIR=/workspace

# Default non-root user name inside the container.
DEFAULT_USER=developer

# System locale (passed to apt's locale-gen and exported as LANG/LC_ALL).
LOCALE=en_US.UTF-8

# X11 display number for GUI forwarding.
DISPLAY_NUM=:1

# Which GPUs the container can see. Set to a comma-separated list of indices
# (e.g. "0,1") to restrict, or "all" for all visible GPUs.
NVIDIA_VISIBLE_DEVICES=all
